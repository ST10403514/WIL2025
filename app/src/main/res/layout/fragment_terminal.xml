<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/mainLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#2C3E50"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#1A5276"
        android:padding="12dp">

        <TextView
            android:id="@+id/headerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MoveWithMe"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true" />

        <Button
            android:id="@+id/logoutButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:textAllCaps="false"
            android:textSize="14sp"
            android:paddingLeft="12dp"
            android:paddingRight="12dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:backgroundTint="#2874A6"
            android:textColor="#FFFFFF" />
    </RelativeLayout>

    <!-- Image Area -->
    <FrameLayout
        android:id="@+id/imageArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/image_placeholder_background">

        <ImageView
            android:id="@+id/ivJump"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center" />
    </FrameLayout>

    <!-- Jump Counters -->
    <LinearLayout
        android:id="@+id/jumpStatsLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="3"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/jump_stat_background"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:id="@+id/tvJumpLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumps Left"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/jump_stat_background"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:id="@+id/tvJumpMiddle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumps Up"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:background="@drawable/jump_stat_background"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp">
            <TextView
                android:id="@+id/tvJumpRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Jumps Right"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <Button
        android:id="@+id/showView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Show"/>
    <!-- Buttons View (to show/hide all main buttons) -->
    <LinearLayout
        android:id="@+id/buttonsView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Jump Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnJumpLeft"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="Jump Left"
                android:textColor="#FFFFFF"
                android:background="@drawable/jump_stat_background"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnJumpUp"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="Jump Up"
                android:textColor="#FFFFFF"
                android:background="@drawable/jump_stat_background"
                android:layout_marginEnd="8dp"/>

            <Button
                android:id="@+id/btnJumpRight"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:text="Jump Right"
                android:textColor="#FFFFFF"
                android:background="@drawable/jump_stat_background"/>
        </LinearLayout>

        <!-- Show / Hide / LED / Login Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">



            <Button
                android:id="@+id/hideView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hide"
                android:layout_marginStart="16dp"/>

            <Button
                android:id="@+id/hideLEDView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LED"
                android:layout_marginStart="16dp"/>

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Login"
                android:layout_marginStart="16dp"/>
        </LinearLayout>

        <!-- LED Options Layout -->
        <LinearLayout
            android:id="@+id/ledOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/btnRed" android:layout_width="100dp" android:layout_height="50dp" android:text="Red" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnGreen" android:layout_width="100dp" android:layout_height="50dp" android:text="Green" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnBlue" android:layout_width="100dp" android:layout_height="50dp" android:text="Blue" android:layout_margin="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/btnWhite" android:layout_width="100dp" android:layout_height="50dp" android:text="White" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnTopaz" android:layout_width="100dp" android:layout_height="50dp" android:text="Topaz" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnLilac" android:layout_width="100dp" android:layout_height="50dp" android:text="Lilac" android:layout_margin="4dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp">

                <Button android:id="@+id/btnRainbow" android:layout_width="wrap_content" android:layout_height="50dp" android:text="Rainbow" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnSeizureMode" android:layout_width="wrap_content" android:layout_height="50dp" android:text="Seizure Mode" android:layout_margin="4dp"/>
                <Button android:id="@+id/btnLEDOff" android:layout_width="100dp" android:layout_height="50dp" android:text="Off" android:layout_margin="4dp"/>
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Received Text Section -->
    <TextView
        android:id="@+id/receive_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.4"
        android:gravity="bottom"
        android:textColor="#FFFFFF"
        android:scrollbars="vertical"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"/>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="?android:attr/listDivider"/>

    <!-- Send Text Section -->
    <LinearLayout
        android:id="@+id/sendLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/send_text"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:inputType="text|textNoSuggestions"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A5276"
            android:padding="8dp"/>

        <ImageButton
            android:id="@+id/send_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:backgroundTint="#2874A6"
            android:src="@android:drawable/ic_menu_send"/>
    </LinearLayout>

</LinearLayout>
